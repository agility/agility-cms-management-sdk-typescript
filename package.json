{
  "name": "@agility/management-sdk",
  "version": "0.1.23",
  "description": "Agility CMS Tyescript SDK for Management API.",
  "repository": {
    "type": "git",
    "url": "https://github.com/agility/agility-cms-management-sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/agility/agility-cms-management-sdk-typescript/issues"
  },
  "homepage": "https://github.com/agility/agility-cms-management-sdk-typescript#readme",
  "main": "dist/index.js",
  "scripts": {
    "clean": "git clean -Xf && rm -rf ./dist",
    "build": "tsc",
    "prepare": "yarn build",
    "test": "jest",
    "test:dev": "TEST_ENV=DEV jest",
    "test:prod-us": "TEST_ENV=PROD_US jest",
    "test:prod-aus": "TEST_ENV=PROD_AUS jest",
    "test:prod-eu": "TEST_ENV=PROD_EU jest",
    "test:prod-ca": "TEST_ENV=PROD_CA jest",
    "test:preprod-content": "TEST_ENV=PREPROD_CONTENT_SERVER jest",
    "test:preprod-fetch": "TEST_ENV=PREPROD_FETCHAPI jest",
    "test:auth:dev": "TEST_ENV=DEV jest src/tests/auth.test.ts",
    "test:auth:prod": "TEST_ENV=PROD_US jest src/tests/auth.test.ts",
    "test:dev:page": "TEST_ENV=DEV jest src/tests/methods/pageMethods.test.ts",
    "test:dev:serverUser": "TEST_ENV=DEV jest src/tests/methods/serverUserMethods.test.ts",
    "test:dev:webhook": "TEST_ENV=DEV jest src/tests/methods/webhookMethods.test.ts",
    "test:dev:container": "TEST_ENV=DEV jest src/tests/methods/containerMethods.test.ts",
    "test:dev:content": "TEST_ENV=DEV jest src/tests/methods/contentMethods.test.ts",
    "test:dev:instance": "TEST_ENV=DEV jest src/tests/methods/instanceMethods.test.ts",
    "test:dev:instanceUser": "TEST_ENV=DEV jest src/tests/methods/instanceUserMethods.test.ts",
    "test:dev:model": "TEST_ENV=DEV jest src/tests/methods/modelMethods.test.ts",
    "test:dev:asset": "TEST_ENV=DEV jest src/tests/methods/assetMethods.test.ts",
    "test:dev:batch": "TEST_ENV=DEV jest src/tests/methods/batchMethods.test.ts"
  },
  "keywords": [
    "typescript",
    "agility",
    "cms",
    "headlesscms",
    "management-api"
  ],
  "author": "Agility CMS",
  "contributors": [
    "Joel Varty",
    "Mohit Vashishtha",
    "Kevin Tran",
    "Aaron Taylor"
  ],
  "license": "MIT",
  "dependencies": {
    "@azure/data-tables": "^13.3.0",
    "dotenv": "^16.5.0",
    "form-data": "^4.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.11.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2"
  }
}
